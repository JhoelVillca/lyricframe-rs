# Now Playing Widget - Environment Variables
# Copy this file to .env and fill in your values
# You only need to configure ONE service (Spotify OR Last.fm)

# ===================
# SPOTIFY (Option 1)
# ===================
# Get these from https://developer.spotify.com/dashboard/applications

# See SetUp.md for detailed instructions on obtaining the refresh token

SPOTIFY_CLIENT_ID=1103376e57934e97ac37e6769beabeb6
SPOTIFY_SECRET_ID=71c06aabd1d349e0803d3908dcede28b
SPOTIFY_REFRESH_TOKEN=AQA7gHiVXjNDS9G0AkJFKjab6Em64sV32ic2Gr-8iAXhYl1uNetB4GyBaxJKzIWXXXWCY_tvo30mynKcuiMAculX1FqHnUsvAVGvirJ1eiIAx61RCs1zCWPVwrMIwuTxLbo

# ===================
# https://accounts.spotify.com/authorize?client_id=1103376e57934e97ac37e6769beabeb6&response_type=code&scope=user-read-currently-playing,user-read-recently-played&redirect_uri=https://example.com/callback
# LAST.FM (Option 2)
# ===================
# Get your API key from https://www.last.fm/api/account/create
# Your username is visible in your Last.fm profile URL

LAST_FM_API_KEY=your_lastfm_api_key_here
LAST_FM_USERNAME=your_lastfm_username_here
